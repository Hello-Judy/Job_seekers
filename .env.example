# Copy this file to .env and fill in your actual credentials.
# Never commit .env to git.

# ==== Snowflake ====
SNOWFLAKE_ACCOUNT=xxxxxxx-xxxxxxx          # e.g. abc12345.us-east-1
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=JOBSEEKERS
SNOWFLAKE_SCHEMA_BRONZE=BRONZE
SNOWFLAKE_SCHEMA_SILVER=SILVER
SNOWFLAKE_SCHEMA_GOLD=GOLD

# ==== Adzuna API ====
# Get free keys at https://developer.adzuna.com/
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key
ADZUNA_COUNTRY=us

# ==== USAJobs API ====
# Get free key at https://developer.usajobs.gov/apirequest/
USAJOBS_API_KEY=your_api_key
USAJOBS_USER_AGENT=your_email@example.com
